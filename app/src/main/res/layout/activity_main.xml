<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/bg_main"
    android:paddingTop="?attr/actionBarSize">


    <!-- 顶部固定区域背景（与下方信息流形成视觉区分） -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 顶部频道按钮组 + 右上角三点菜单 -->
        <LinearLayout
            android:id="@+id/channel_layout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_channel_1"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="精选"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textColor="@color/primary_dark"
                    android:background="@drawable/bg_channel_btn_selected"
                    android:layout_marginEnd="10dp"/>

                <Button
                    android:id="@+id/btn_channel_2"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="推荐"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_channel_btn_normal"
                    android:layout_marginHorizontal="5dp"/>

                <Button
                    android:id="@+id/btn_channel_3"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="本地"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_channel_btn_normal"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>

            <!-- 右上角三点菜单按钮 -->
            <ImageView
                android:id="@+id/btn_more"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/baseline_more_vert_24"
                android:contentDescription="更多"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 搜索框 -->
    <LinearLayout
        android:id="@+id/search_layout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_search_box"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="5dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/header_container">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_search"
            android:layout_gravity="center_vertical"/>

        <LinearLayout
            android:id="@+id/search_hint_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:orientation="vertical"
            android:clipChildren="false">

            <TextView
                android:id="@+id/search_hint_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="找运动相关的广告"
                android:textColor="@color/text_hint"
                android:textSize="14sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_search"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="搜索"
            android:textSize="12sp"
            android:textColor="@color/primary_dark"
            android:background="@drawable/bg_search_btn_main"
            android:paddingHorizontal="12dp"
            android:layout_gravity="center_vertical"/>
    </LinearLayout>

    <!-- 标签过滤区域 -->
    <LinearLayout
        android:id="@+id/filter_tag_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:minHeight="40dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/search_layout">

        <!-- 引导文字 -->
        <TextView
            android:id="@+id/filter_hint_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击卡片标签过滤下方内容"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:visibility="visible"/>

        <!-- 已选标签容器 -->
        <LinearLayout
            android:id="@+id/selected_tags_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- 顶部内容区域 + 底部阴影（替换纯Barrier，实现6dp边距+阴影） -->
    <View
        android:id="@+id/top_content_shadow"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginHorizontal="6dp"
        android:background="@drawable/top_bottom_shadow"
        app:layout_constraintTop_toBottomOf="@id/filter_tag_container"/>

    <!-- ViewPager2 内容区域（占满剩余高度） -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_content_shadow"
        app:layout_constraintVertical_bias="1.0"
        tools:layout_editor_absoluteX="55dp" />

</androidx.constraintlayout.widget.ConstraintLayout>